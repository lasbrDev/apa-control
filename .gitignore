# =====================================================
# APA CONTROL - Git Ignore
# =====================================================

# Environment Variables (NEVER commit!)
.env
.env.local
.env.development
.env.test
.env.production
.env.staging
# Allow .env.example files
!.env.example

# =====================================================
# Dependencies
# =====================================================
node_modules/
jspm_packages/
bower_components/

# =====================================================
# Build outputs
# =====================================================
dist/
build/
publish/build/
.next/
.nuxt/
.vuepress/dist/

# =====================================================
# TypeScript
# =====================================================
*.tsbuildinfo
typings/

# =====================================================
# Logs
# =====================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
api.log

# =====================================================
# Testing & Coverage
# =====================================================
coverage/
*.lcov
.nyc_output/
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# =====================================================
# Cache & Temp files
# =====================================================
.cache/
.turbo/
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/
.fusebox/

# =====================================================
# Runtime data
# =====================================================
pids/
*.pid
*.seed
*.pid.lock

# =====================================================
# OS Files
# =====================================================
.DS_Store
Thumbs.db
Desktop.ini

# =====================================================
# IDE & Editors
# =====================================================
.idea/
*.swp
*.swo
*~

# =====================================================
# Optional configs
# =====================================================
.npm
.yarn-integrity
.node_repl_history
.lock-wscript
lib-cov
.grunt
.tern-port

# =====================================================
# Serverless & Cloud
# =====================================================
.serverless/
.vercel/
.dynamodb/

# =====================================================
# Database
# =====================================================
*.sqlite
*.sqlite3
*.db
pgdata/

# =====================================================
# Uploads & User Generated Content
# =====================================================
uploads/
temp/
tmp/

# =====================================================
# Package manager outputs
# =====================================================
*.tgz
package-lock.json
yarn.lock
