{
  "name": "@apa-control/api",
  "version": "1.0.0",
  "description": "API Backend do sistema ERP",
  "main": "dist/server.js",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "tsup",
    "start": "node dist/server.js",
    "dev": "tsx watch --inspect --env-file .env src/server.ts",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "@date-fns/tz": "^1.2.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/multipart": "^9.2.1",
    "@fastify/rate-limit": "^10.3.0",
    "@sentry/node": "^10.20.0",
    "axios": "^1.12.2",
    "bcryptjs": "^3.0.2",
    "date-fns": "^4.1.0",
    "decimal.js": "^10.6.0",
    "drizzle-kit": "^0.31.5",
    "drizzle-orm": "^0.44.6",
    "ejs": "^3.1.10",
    "fastify": "^5.6.1",
    "fastify-plugin": "^5.1.0",
    "json-2-csv": "^5.5.9",
    "jsonwebtoken": "^9.0.2",
    "linebreak": "^1.1.0",
    "nodemailer": "^7.0.9",
    "pg": "^8.16.3",
    "playwright": "^1.48.2",
    "request-ip": "^3.3.0",
    "sharp": "^0.34.4",
    "uuid": "^13.0.0",
    "winston": "^3.18.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@apa-control/tsconfig": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/ejs": "^3.1.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.7.2",
    "@types/nodemailer": "7.0.2",
    "@types/pg": "^8.15.5",
    "@types/request-ip": "^0.0.41",
    "@vitest/coverage-v8": "^2.1.4",
    "form-data": "^4.0.4",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
