<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <title><%= title %></title>
    <style>
      @page { size: A4 landscape; }
      body { font-family: Arial, sans-serif; font-size: 12px; color: #111; }
      .header { margin-bottom: 16px; }
      .brand { text-align: center; margin-bottom: 10px; }
      .brand img { max-height: 96px; width: auto; }
      .title { font-size: 18px; font-weight: 700; margin-bottom: 6px; }
      .meta { color: #555; margin-bottom: 2px; }
      .animal-info { margin-bottom: 20px; border: 1px solid #ddd; padding: 12px; border-radius: 4px; background: #fafafa; }
      .animal-info h3 { margin-top: 0; margin-bottom: 10px; font-size: 14px; }
      .info-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
      .info-item strong { font-weight: 600; }
      table { width: 100%; border-collapse: collapse; }
      th, td { border: 1px solid #ddd; padding: 6px; text-align: left; }
      td { word-break: break-word; overflow-wrap: break-word; }
      th { background: #f5f5f5; white-space: nowrap; }
      th:nth-child(5), td:nth-child(5) { width: 35%; } /* Valor Novo */
    </style>
  </head>
  <body>
    <div class="header">
      <% if (locals.logoDataUrl) { %>
      <div class="brand">
        <img src="<%= locals.logoDataUrl %>" alt="APA Control" />
      </div>
      <% } %>
      <div class="title"><%= title %></div>
      <div class="meta">Gerado em: <%= generatedAt %></div>
    </div>

    <% if (locals.animal) { %>
    <div class="animal-info">
      <h3>Dados do Animal</h3>
      <div class="info-grid">
        <div class="info-item"><strong>Nome:</strong> <%= locals.animal.name %></div>
        <div class="info-item"><strong>Espécie:</strong> <%= locals.animal.species %></div>
        <div class="info-item"><strong>Raça:</strong> <%= locals.animal.breed || 'Não definida' %></div>
        <div class="info-item"><strong>Porte:</strong> <%= locals.animal.size %></div>
        <div class="info-item"><strong>Sexo:</strong> <%= locals.animal.sex %></div>
        <div class="info-item"><strong>Ano de Nasc.:</strong> <%= locals.animal.birthYear || '-' %></div>
        <div class="info-item"><strong>Condição de Saúde:</strong> <%= locals.animal.healthCondition %></div>
        <div class="info-item"><strong>Status:</strong> <%= locals.animal.status %></div>
        <div class="info-item"><strong>Entrada:</strong> <%= locals.animal.entryDate %></div>
      </div>
    </div>
    <% } %>

    <% if (locals.rescue) { %>
    <div class="animal-info">
      <h3>Dados do Resgate</h3>
      <div class="info-grid">
        <div class="info-item"><strong>Data do Resgate:</strong> <%= locals.rescue.rescueDate %></div>
        <div class="info-item" style="grid-column: span 2;"><strong>Local Encontrado:</strong> <%= locals.rescue.locationFound || '-' %></div>
        <div class="info-item" style="grid-column: span 3;"><strong>Circunstâncias:</strong> <%= locals.rescue.circumstances || '-' %></div>
        <div class="info-item" style="grid-column: span 3;"><strong>Condições Encontradas:</strong> <%= locals.rescue.foundConditions || '-' %></div>
        <div class="info-item" style="grid-column: span 3;"><strong>Procedimentos Imediatos:</strong> <%= locals.rescue.immediateProcedures || '-' %></div>
        <div class="info-item" style="grid-column: span 3;"><strong>Observações do Resgate:</strong> <%= locals.rescue.observations || '-' %></div>
      </div>
    </div>
    <% } %>

    <table>
      <thead>
        <tr>
          <% headers.forEach((header) => { %>
          <th><%= header %></th>
          <% }) %>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach((row) => { %>
        <tr>
          <% row.forEach((cell) => { %>
          <td><%= cell ?? '' %></td>
          <% }) %>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </body>
</html>
