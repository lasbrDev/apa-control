# Servidor
PORT=3333
NODE_ENV=development

# Aplicação
APP_NAME=APA Control
APP_SECRET=your-secret-key-here-change-in-production
APP_LOG_DIR=./logs

# Banco de Dados
# Para desenvolvimento local, use sua instância PostgreSQL local:
DATABASE_URL=postgresql://usuario:senha@localhost:5432/apa_control

# Para produção com Neon (após migração):
# DATABASE_URL será fornecido automaticamente pelo Neon
# Exemplo: postgresql://user:password@ep-xyz-123.us-east-2.aws.neon.tech/apa_control

# Para PRs no GitHub:
# O Neon criará automaticamente branches de preview via GitHub Actions
# O DATABASE_URL será injetado automaticamente no workflow

# Email (configurações para envio de notificações)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu-email@gmail.com
EMAIL_PASSWORD=sua-senha-de-app
OVERRIDE_EMAIL=email-para-testes@exemplo.com
